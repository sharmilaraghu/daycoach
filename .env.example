# ──────────────────────────────────────────────────────────────────────────────
# DayCoach — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.
# ──────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Neon, Supabase, or any Postgres)
# Get a free Neon DB at: https://neon.tech
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ElevenLabs API key
# Get it at: https://elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=

# ElevenLabs Conversational AI Agent IDs (one per persona)
# Create 4 agents in ElevenLabs dashboard, paste the IDs here.
# See documentation/SETUP.md for full agent configuration steps.
ELEVENLABS_AGENT_SUNNY=
ELEVENLABS_AGENT_COACH=
ELEVENLABS_AGENT_COMMANDER=
ELEVENLABS_AGENT_CHAMPION=

# Session secret — any random string, used for Express session signing
SESSION_SECRET=change-me-to-a-random-string

# Runtime
NODE_ENV=development
PORT=8080
